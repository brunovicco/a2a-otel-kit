APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=a2a-otel-kit

# a2a-otel-kit observability settings (see README.md#configuration).
# Leave A2A_OTEL_ENABLED unset/false to keep tracing fully disabled (no-op, no endpoint needed).
# A2A_OTEL_SERVICE_NAME=a2a-otel-kit
# A2A_OTEL_SERVICE_VERSION=0.4.1
# A2A_OTEL_ENVIRONMENT=development
# A2A_OTEL_ENABLED=false
# A2A_OTEL_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# A2A_OTEL_OTLP_TIMEOUT_SECONDS=10
# A2A_OTEL_LOG_LEVEL=INFO
# A2A_OTEL_LOG_FORMAT=json
